    <value>100</value>
    <minimum>0</minimum>
    <maximum>50000</maximum>
  </parameter>
  <parameter>
    <name>StartY</name>
    <description>The first coordinate along Y axis to analyze</description>
    <type>java.lang.Integer</type>
    <value>100</value>
    <minimum>0</minimum>
    <maximum>50000</maximum>
  </parameter>
